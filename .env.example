# Authentication
API_KEY=your-api-key-here

# Integration mode: "demo" (simulated) or "live" (real HTTP calls)
INTEGRATION_MODE=demo

# Back-office API — required for live mode
API_BASE_URL=https://api.yourbackoffice.com
BACKOFFICE_API_KEY=

# Twilio (for live outbound calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OpenAI (optional — enables AI itinerary parsing)
OPENAI_API_KEY=

# Database
DATABASE_URL=sqlite:///calls.db

# Logging
LOG_LEVEL=INFO

# Pricing multipliers (optional overrides)
PRICING_ECONOMY_MULTIPLIER=1.0
PRICING_PREMIUM_MULTIPLIER=1.35
PRICING_BUSINESS_MULTIPLIER=1.9
